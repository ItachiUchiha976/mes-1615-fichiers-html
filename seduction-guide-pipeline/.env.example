# ─── Gemini (obligatoire) ──────────────────────────────────────────────────────
GEMINI_API_KEY=your_gemini_api_key_here

# ─── OpenAI Whisper API (optionnel – si tu préfères le cloud Whisper d'OpenAI) ─
# Laisser vide pour utiliser Whisper local (gratuit, tourne sur CPU/GPU)
OPENAI_API_KEY=

# ─── Google Drive OAuth2 (obligatoire si tu utilises le module Drive) ──────────
# Télécharge "credentials.json" depuis Google Cloud Console
# (API & Services → OAuth 2.0 → Desktop App) et place-le ici.
GDRIVE_CREDENTIALS_FILE=credentials.json
GDRIVE_TOKEN_FILE=token.json

# ─── Répertoires de travail ────────────────────────────────────────────────────
# Dossier où les vidéos/audio seront téléchargés
DOWNLOAD_DIR=downloads
# Dossier où les transcriptions texte seront sauvegardées
TRANSCRIPTS_DIR=transcripts
# Fichier final fusionné
MERGED_TRANSCRIPT=merged_transcript.txt
# Guide final généré
OUTPUT_GUIDE=guide_seduction_complet.md
